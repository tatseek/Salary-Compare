generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id          String        @id @default(cuid())
  name        String        @unique
  slug        String        @unique
  logo        String?
  website     String?
  industry    String?
  createdAt   DateTime      @default(now())
  salaries    SalaryEntry[]
}

model Location {
  id        String        @id @default(cuid())
  city      String
  state     String?
  country   String
  region    String
  salaries  SalaryEntry[]

  @@unique([city, country])
}

model SalaryEntry {
  id            String    @id @default(cuid())
  companyId     String
  locationId    String
  role          String
  level         String
  yearsOfExp    Int
  baseSalary    Float
  bonus         Float     @default(0)
  stockPerYear  Float     @default(0)
  totalComp     Float
  currency      String    @default("USD")
  remote        Boolean   @default(false)
  verified      Boolean   @default(false)
  submittedAt   DateTime  @default(now())

  company       Company   @relation(fields: [companyId], references: [id])
  location      Location  @relation(fields: [locationId], references: [id])

  @@index([role])
  @@index([level])
  @@index([companyId])
  @@index([locationId])
  @@index([totalComp])
}
